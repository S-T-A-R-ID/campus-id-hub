# Backend (Supabase Edge Functions) environment variables
# Copy to: supabase/functions/.env.local for local function serving

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Used by admin/auth flows to generate redirect links
AUTH_REDIRECT_BASE_URL=http://localhost:3000
